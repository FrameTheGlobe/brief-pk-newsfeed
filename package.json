{
  "name": "brief-pk-newsfeed",
  "version": "5.0.6",
  "private": true,
  "description": "brief.pk — Pakistan Intelligence Dashboard",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "backend": "node backend/server.js",
